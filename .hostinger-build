#!/bin/bash
# Script de build para Hostinger
# Este arquivo é usado pela Hostinger para fazer o build automático

echo "🔨 Instalando dependências..."
npm install --legacy-peer-deps

echo "📦 Gerando tipos do Wrangler..."
npm run cf-typegen 2>/dev/null || echo "⚠️  cf-typegen falhou, continuando..."

echo "🏗️  Executando build..."
npm run build

echo "✅ Build concluído!"

